{
  "name": "rust-nix-hm",
  "build": {
    "dockerfile": "../devcontainer.dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "overrideCommand": false,
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "jnoortheen.nix-ide"
      ]
    }
  }
}